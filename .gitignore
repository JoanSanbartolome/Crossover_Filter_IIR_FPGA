*.vvp
*.vcd
*.fst
*.lxt
*.lxt2
sim/**/obj_dir/

#-----------------------------------------------------------------------------
# Waveform dumps
#-----------------------------------------------------------------------------
*.vcd
*.fst
*.ghw
*.wlf

#-----------------------------------------------------------------------------
# Python - Cache, entornos virtuales y bytecode
#-----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.eggs/
*.whl
pip-log.txt
pip-delete-this-directory.txt

# Entornos virtuales
.venv/
venv/
ENV/
env/

# Jupyter Notebooks
.ipynb_checkpoints/

#-----------------------------------------------------------------------------
# Datos generados - Estimulos, capturas y salidas
#-----------------------------------------------------------------------------
sim/data/*
!sim/data/.gitkeep
captures/*
!captures/.gitkeep
scripts/*.bin
scripts/*.png

#-----------------------------------------------------------------------------
# IDE y editores
#-----------------------------------------------------------------------------
# VS Code / Antigravity
.vscode/
.gemini/

# Obsidian
.obsidian/

# JetBrains
.idea/

# Vim/Neovim
*.swp
*.swo
*~

