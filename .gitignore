gowin/**/*.power
gowin/**/*.pin
gowin/**/*.tr
gowin/**/*.posp
gowin/**/*.json.bak

#-----------------------------------------------------------------------------
# ModelSim - Archivos de simulacion y logs en la raiz/local
#-----------------------------------------------------------------------------
modelsim.ini
vsim.wlf
transcript
wlft*
sim/work/
sim/**/*.wlf
sim/**/*.vstf
sim/**/*.ucdb
sim/**/transcript
sim/**/vsim.wlf
sim/**/modelsim.ini
sim/**/_info
sim/**/_vmake
sim/**/_lock
sim/**/*.cr.mti
sim/**/*.mpf

